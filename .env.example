# Frontend flag-state polling interval in milliseconds (default: 3000)
FLAG_POLL_INTERVAL_MS=3000

# Flask server port (default: 5001 — avoids macOS AirPlay on port 5000)
PORT=5001

# LaunchDarkly server-side SDK key
# Location: LD dashboard > Settings cog > SDK keys > Server-side SDK key
LAUNCHDARKLY_SDK_KEY=sdk-your-key-here

# Anthropic API key (used for the AI suggestion feature)
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# LaunchDarkly flag trigger URL (for the Remediate demo)
# Location: LD dashboard > Flags > ai-response-suggestions > Configuration in environment > Add trigger
# Leave blank if you have not yet created the trigger.
LD_TRIGGER_URL=

# LaunchDarkly client-side environment key (for JS SDK — Session Replay & Observability)
# Location: LD dashboard > Settings cog > SDK keys > Client-side ID
LAUNCHDARKLY_CLIENT_ID=your-client-side-id-here

# New Relic APM (optional — app runs normally without these)
# Location: New Relic One > API keys > Ingest - License
NEW_RELIC_LICENSE_KEY=
# NEW_RELIC_APP_NAME="SupportIQ Demo"

# Optional: git SHA passed to LD Observability as service_version
GIT_SHA=
